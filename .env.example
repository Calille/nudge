# Copy to .env (gitignored) and fill in before running `npm run dev` or
# `npm run dist:win`. main.ts loads this file via dotenv at boot in dev;
# production builds bake the values into the bundle at compile time.

# ── Microsoft / Outlook OAuth ────────────────────────────────────────
# Register an app at https://portal.azure.com → Microsoft Entra ID →
# App registrations → New registration.
#   Supported account types: pick "Single tenant only" if sending only
#     from your own organisation, or "Any Entra ID + personal accounts"
#     if you need broader reach.
#   Authentication → Add a platform → Mobile and desktop applications
#     → register redirect URI:  http://localhost
#   API permissions → Add a permission → Microsoft Graph → Delegated
#     → Mail.Send, offline_access, User.Read
#   (no client secret needed — this is a public client flow)
MS_OAUTH_CLIENT_ID=
# For single-tenant apps use your Entra tenant GUID. Use `common` only
# if your app supports multi-tenant or personal accounts.
MS_OAUTH_TENANT_ID=common
