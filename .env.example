# Copy to .env (gitignored) and fill in before running `npm run dev`.
# main.ts loads this file via dotenv at boot; values populate process.env
# for the main process only — the renderer never sees them.

# ── Microsoft / Outlook OAuth ────────────────────────────────────────
# Register an app at https://portal.azure.com → Microsoft Entra ID →
# App registrations → New registration.
#   Supported account types: choose the option that includes "personal
#     Microsoft accounts" if you're testing with a Hotmail/Outlook.com
#     address.
#   Authentication → Add a platform → Mobile and desktop applications
#     → register redirect URI:  http://localhost
#   API permissions → Add a permission → Microsoft Graph → Delegated
#     → Mail.Send, offline_access, User.Read
#   (no client secret needed — this is a public client flow)
MS_OAUTH_CLIENT_ID=
# `common` lets any Microsoft account sign in. Use your tenant GUID if
# you want to restrict to your organisation.
MS_OAUTH_TENANT_ID=common

# ── Gmail OAuth ──────────────────────────────────────────────────────
# Register at https://console.cloud.google.com → APIs & Services →
# Credentials → Create OAuth client ID → Desktop application.
# Enable the Gmail API on the project first.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
